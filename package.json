{
  "name": "mind-map-infinite-canvas",
  "description": "Infinite canvas mind map app built with Vite, vanilla JavaScript, and Konva.js.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && pnpm export:html",
    "export:html": "node scripts/build-export-template.mjs",
    "export:shell:refresh": "pnpm export:html",
    "preview": "vite preview",
    "test": "pnpm test:smoke && pnpm test:unit && pnpm test:e2e",
    "test:smoke": "pnpm build",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --headed"
  },
  "dependencies": {
    "konva": "^9.3.22",
    "lucide": "^0.577.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "jsdom": "^26.1.0",
    "vite": "^8.0.0",
    "vitest": "^3.2.4"
  }
}
